# Copy this file to .env.local for local dev, and add these to Vercel:
# Vercel Dashboard → Project → Settings → Environment Variables

# Supabase — supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Gmail — myaccount.google.com → Security → App Passwords
# Create an App Password for "Mail" (requires 2-Step Verification to be on)
GMAIL_USER=thedamlekdigital@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password

# Admin dashboard — thedamlekdigital.vercel.app/admin
# Set this to any strong password your team will use to log in
ADMIN_PASSWORD=choose-a-strong-team-password-here

# MailerLite — app.mailerlite.com → Integrations → API
MAILERLITE_API_KEY=your-mailerlite-api-key-here

# MailerLite group IDs (one per scorecard tier) — see docs/mailerlite-setup.md
MAILERLITE_GROUP_FOUNDATION=
MAILERLITE_GROUP_GROWTH=
MAILERLITE_GROUP_SCALE=
MAILERLITE_GROUP_PERFORMANCE=
